# SendRepo GitHub Actions runner — environment template.
# Copy to .env next to docker-compose.yaml, fill in, then: docker compose up -d --build
#
#   cp .env.example.runner .env
#
# NOTE: .env holds secrets — keep it out of version control (add it to .gitignore).

# ── Required ────────────────────────────────────────────────────────────────
# The repo (or org) the runner attaches to.
#   Repo-level: https://github.com/your-org/your-repo
#   Org-level:  https://github.com/your-org
REPO_URL=https://github.com/your-org/your-repo

# ── Auth: provide ONE of the two below ──────────────────────────────────────
#
# Option A (PREFERRED) — ACCESS_TOKEN: a long-lived Personal Access Token.
#   Scope: "repo" (repo-level runner) or "admin:org" (org-level runner).
#   The entrypoint exchanges it for a fresh registration token on EVERY start,
#   so container restarts always re-register cleanly. This is what you want for
#   a long-running runner.
ACCESS_TOKEN=ghp_replace_me

# Option B — RUNNER_TOKEN: a short-lived registration token.
#   Get it from: repo/org Settings > Actions > Runners > New self-hosted runner.
#   WARNING: expires in ~1 hour. If the container restarts after it expires,
#   registration FAILS. Use only for a quick, throwaway runner.
#   If you use this, leave ACCESS_TOKEN blank/commented.
# RUNNER_TOKEN=AXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Optional ────────────────────────────────────────────────────────────────
# Name shown in GitHub's runner list (defaults to the container hostname).
RUNNER_NAME=sendrepo-runner

# Labels your workflow targets, e.g. `runs-on: [self-hosted, sendrepo]`.
RUNNER_LABELS=self-hosted,sendrepo
